# ══════════════════════════════════════════════════════════════
# MacroPulse – Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# ══════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── FRED API (required) ──────────────────────────────────────
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Database ─────────────────────────────────────────────────
DB_HOST=timescaledb   # use "localhost" for local dev outside Docker
DB_PORT=5432
DB_USER=macropulse
DB_PASSWORD=change_me_in_production
DB_NAME=macropulse

# ── Auth ─────────────────────────────────────────────────────
# Empty list = dev-mode (no auth enforced).
# In production, leave empty — keys are managed in the DB.
API_KEYS=[]

# ── CORS ─────────────────────────────────────────────────────
# Production: add your site domain
CORS_ORIGINS=["https://macropulse.live","https://www.macropulse.live","http://localhost:3000"]

# ── Rate limiting ────────────────────────────────────────────
# 0 = disabled globally (tier limits from DB apply per-key)
RATE_LIMIT_PER_DAY=0

# ── Model ────────────────────────────────────────────────────
DEFAULT_MODEL_VERSION=v2

# ── Scheduler ────────────────────────────────────────────────
PIPELINE_CRON_HOUR=18    # 18:00 UTC = after US market close
PIPELINE_CRON_MINUTE=30

# ── Paddle Billing ───────────────────────────────────────────
# Get these from https://vendors.paddle.com
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox              # change to "production" when live
PADDLE_CLIENT_TOKEN=                    # Paddle Dashboard → Developer Tools → Authentication
PADDLE_STARTER_PRICE_ID=               # pri_01... (create in Paddle → Catalog → Prices)
PADDLE_PRO_PRICE_ID=                   # pri_01...
PADDLE_SUCCESS_URL=https://macropulse.live/welcome

# ── Alerting (optional) ──────────────────────────────────────
# Slack or Discord webhook for pipeline failure alerts
WEBHOOK_URL=

# Email alerts (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=[]
