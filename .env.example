# ══════════════════════════════════════════════════════
# MacroPulse – Environment Configuration
# ══════════════════════════════════════════════════════

# ── FRED API (required) ──────────────────────────────
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=macropulse
DB_PASSWORD=macropulse
DB_NAME=macropulse

# ── Auth (empty = dev mode, no auth enforced) ────────
# Generate keys with: python -c "from api.auth import generate_api_key; print(generate_api_key())"
API_KEYS=[]

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Scheduler ────────────────────────────────────────
PIPELINE_CRON_HOUR=18
PIPELINE_CRON_MINUTE=30

# ── Model ────────────────────────────────────────────
DEFAULT_MODEL_VERSION=v1

# ── Alerting (optional) ─────────────────────────────
# Slack / Discord webhook
WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=[]

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO
